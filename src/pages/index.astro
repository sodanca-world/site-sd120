---
import siteData from '../data/siteData.json';
import '../styles/global.css';

const { idiomas, configuracoes } = siteData;

const langPaths = {
  pt: '/pt/',
  en: '/en/',
  au: '/au/',
  fr: '/fr/',
  it: '/it/',
  es: '/es/'
};
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Só Dança - SD120 Super Pró</title>
    <meta name="description" content="Escolha seu idioma para conhecer a sapatilha de meia-ponta premium SD120 Super Pró Só Dança." />
    <link rel="icon" type="image/jpeg" href="/assets/images/boneco-so-danca-400x400.jpg" />
    
    <!-- Meta tags AEO básicas -->
    <meta name="llm-description" content="Página de seleção de idioma oficial da Só Dança para a sapatilha premium SD120 Super Pró." />
  </head>
  <body>
    <main class="select-lang-section">
      <div class="bg-overlay"></div>
      
      <div class="container select-container">
        <!-- Logotipo centralizado -->
        <div class="logo-box reveal">
          <img src={`/assets/images/${configuracoes.empresa_logo_imagem}`} alt="Só Dança Logo" class="logo-img" />
        </div>
        
        <!-- Título -->
        <h1 class="select-title reveal delay-1">SD120 Super Pró Só Dança</h1>
        <p class="select-subtitle reveal delay-2">Escolha seu idioma / Select your language</p>
        
        <!-- Grid de Botões de Idioma -->
        <div class="lang-grid reveal delay-3">
          {Object.entries(idiomas).map(([key, value]) => (
            <a 
              href={langPaths[key as keyof typeof langPaths]} 
              class="lang-select-card"
              title={`Acesse em ${value.nome}`}
            >
              <span class="lang-name">{value.nome}</span>
            </a>
          ))}
        </div>
      </div>
    </main>

    <script>
      // Função simples de revelação de scroll para a página de entrada
      const reveals = document.querySelectorAll('.reveal');
      const revealOnLoad = () => {
        reveals.forEach(el => el.classList.add('active'));
      };
      window.addEventListener('load', revealOnLoad);
    </script>
  </body>
</html>

<style>
  .select-lang-section {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/assets/images/hero_sodanca.png');
    background-size: cover;
    background-position: center;
    color: var(--color-white);
    overflow: hidden;
  }

  .bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom, 
      rgba(10, 15, 30, 0.25) 0%, 
      rgba(10, 15, 30, 0.5) 100%
    );
    z-index: 1;
  }

  .select-container {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
  }

  .logo-box {
    width: 240px;
    margin: 0 auto 30px auto;
    color: var(--color-white);
  }

  .logo-img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,0.3));
  }

  .select-title {
    color: var(--color-white);
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 8px;
    letter-spacing: -1.5px;
    text-transform: uppercase;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
  }

  .select-subtitle {
    font-size: 1.25rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 50px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  /* --- GRID DE IDIOMAS --- */
  .lang-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 650px;
    margin: 0 auto;
  }

  .lang-select-card {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50px;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: var(--font-title);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-white);
    transition: var(--transition-smooth);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  .lang-select-card:hover {
    background: var(--color-white);
    color: var(--color-dark);
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(255, 255, 255, 0.2);
    border-color: var(--color-white);
  }

  .flag-large {
    font-size: 1.35rem;
  }

  @media (max-width: 768px) {
    .select-title {
      font-size: 2.5rem;
    }
    .select-subtitle {
      font-size: 1.1rem;
    }
    .lang-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      padding: 0 16px;
    }
  }

  @media (max-width: 480px) {
    .lang-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
