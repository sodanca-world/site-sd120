---
import siteData from '../data/siteData.json';

interface Props {
  lang: 'pt' | 'en' | 'au' | 'fr' | 'it' | 'es';
  hero: {
    titulo: string;
    subtitulo: string;
    btn_contato: string;
  };
}

const { lang, hero } = Astro.props;
const { idiomas, configuracoes } = siteData;

// Mapeamento de caminhos de idioma
const langPaths = {
  pt: '/pt/',
  en: '/en/',
  au: '/au/',
  fr: '/fr/',
  it: '/it/',
  es: '/es/'
};
---

<header class="navbar">
  <div class="container navbar-container">
    <a href="/" class="logo" aria-label="Só Dança Home">
      <div class="logo-wrapper">
        <img src={`/assets/images/${configuracoes.empresa_logo_imagem}`} alt="Só Dança Logo" class="logo-img" />
      </div>
    </a>
    
    <nav class="lang-nav">
      <ul class="lang-list">
        {Object.entries(idiomas).map(([key, value]) => (
          <li>
            <a 
              href={langPaths[key as keyof typeof langPaths]} 
              class={`lang-link ${key === lang ? 'active' : ''}`}
              title={value.nome}
            >
              <span class="lang-code">{key.toUpperCase()}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<section class="hero-section">
  <div class="hero-bg-overlay"></div>
  <div class="container hero-container">
    <div class="hero-content reveal">
      <h1 class="hero-title">{hero.titulo}</h1>
      <p class="hero-subtitle">{hero.subtitulo}</p>
      <div class="hero-actions">
        <a href="#contato" class="btn btn-primary btn-large">
          {hero.btn_contato}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* --- NAVBAR --- */
  .navbar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 24px 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 100%);
  }

  .navbar-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo-wrapper {
    width: 180px;
    color: var(--color-white);
    transition: var(--transition-smooth);
  }

  .logo-wrapper:hover {
    transform: scale(1.02);
  }

  .logo-img {
    width: 100%;
    height: auto;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
  }

  .lang-nav {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 30px;
    padding: 6px 16px;
  }

  .lang-list {
    display: flex;
    gap: 16px;
  }

  .lang-link {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.85rem;
    font-family: var(--font-title);
    font-weight: 600;
    transition: var(--transition-smooth);
    padding: 4px 8px;
    border-radius: 12px;
  }

  .lang-link:hover {
    color: var(--color-white);
  }

  .lang-link.active {
    color: var(--color-white);
    background-color: var(--color-primary);
    box-shadow: 0 4px 10px rgba(var(--primary-hue), var(--primary-sat), var(--primary-light), 0.3);
  }

  .lang-code {
    display: inline;
  }

  @media (max-width: 768px) {
    .logo-wrapper {
      width: 140px;
    }
    .lang-link {
      padding: 4px;
    }
    .lang-nav {
      padding: 4px 8px;
    }
  }

  /* --- HERO SECTION --- */
  .hero-section {
    position: relative;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/assets/images/hero_sodanca.png');
    background-size: cover;
    background-position: center;
    color: var(--color-white);
    padding-top: 80px; /* Desconto da navbar */
  }

  .hero-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom, 
      rgba(10, 15, 30, 0.25) 0%, 
      rgba(10, 15, 30, 0.5) 100%
    );
    z-index: 1;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: 4.5rem;
    font-weight: 800;
    line-height: 1.1;
    color: var(--color-white);
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    margin-bottom: 24px;
    letter-spacing: -1.5px;
    text-transform: uppercase;
  }

  .hero-subtitle {
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 40px;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 992px) {
    .hero-title {
      font-size: 3.5rem;
    }
    .hero-subtitle {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 576px) {
    .hero-title {
      font-size: 2.5rem;
    }
    .hero-subtitle {
      font-size: 1.1rem;
    }
  }
</style>
